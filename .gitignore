# ========================================
# Full-Stack .gitignore (Spring Boot + React + Vite)
# ========================================

# ====================
# Frontend (React + Vite)
# ====================
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
frontend/.env
frontend/.env.local
frontend/.env.development
frontend/.env.test
frontend/.env.production

# Logs
frontend/logs
frontend/*.log
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*

# Editor & OS files
frontend/.vscode/
frontend/.idea/
frontend/.DS_Store
frontend/*.suo
frontend/*.ntvs*
frontend/*.njsproj
frontend/*.sln
frontend/*.sw?

# ====================
# Backend (Spring Boot)
# ====================
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
backend/build/
backend/logs/
backend/*.log

# IDE
backend/.idea/
backend/*.iws
backend/*.iml
backend/*.ipr
backend/.vscode/
backend/.settings/
backend/.apt_generated
backend/.springBeans
backend/.sts4-cache

# Sensitive files
backend/.env
backend/application-*.yml
backend/application-*.properties

# ====================
# General / Both
# ====================
# Environment variables (Global)
.env
.env.local
.env.*.local

# OS generated
.DS_Store
Thumbs.db

# Temporary / Cache
*.tmp
*.bak
*.swp

# Coverage & Test
coverage/
jacoco/
*.lcov

# Misc
HELP.md
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz